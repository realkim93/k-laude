#!/usr/bin/env bash
# klaude — k-laude tmux launcher.
# Spawns a tmux session with a Korean input pane on the left and `claude` on the right.
# Korean lines typed in the left pane are translated via Apple FoundationModels
# (on-device LLM) and injected into the right pane as English keystrokes.

set -euo pipefail

# Resolve symlink chain so SCRIPT_DIR points to the real installation directory
# regardless of how the user invoked this script (PATH symlink, alias, etc.).
resolve_symlink() {
  local target="$1"
  while [ -L "$target" ]; do
    local link
    link="$(readlink "$target")"
    case "$link" in
      /*) target="$link" ;;
      *)  target="$(dirname "$target")/$link" ;;
    esac
  done
  printf '%s' "$target"
}
SELF="$(resolve_symlink "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$( cd "$( dirname "$SELF" )" && pwd )"

SESSION_PREFIX="${KLAUDE_SESSION_PREFIX:-${KC_SESSION_PREFIX:-klaude}}"
SESSION="${SESSION_PREFIX}-$$"
CLAUDE_BIN="${KLAUDE_CLAUDE_BIN:-${KC_CLAUDE_BIN:-claude}}"
INPUT_WIDTH="${KLAUDE_INPUT_WIDTH:-${KC_INPUT_WIDTH:-30}}"
RESPONSE_LANG="${KLAUDE_RESPONSE_LANG:-${KC_RESPONSE_LANG:-ko}}"

err()  { printf '\033[1;31m%s\033[0m\n' "$*" >&2; }
info() { printf '\033[1;36m%s\033[0m\n' "$*"; }

require() {
  command -v "$1" >/dev/null 2>&1 || { err "Required command not found: $1"; exit 127; }
}

require tmux
require python3
command -v "$CLAUDE_BIN" >/dev/null 2>&1 || {
  err "claude CLI not found in PATH (set KLAUDE_CLAUDE_BIN to override)"; exit 127;
}

CLAUDE_FULL="$(command -v "$CLAUDE_BIN")"
REPL_FULL="$SCRIPT_DIR/kc-repl.py"
TRANSLATE_BIN="$SCRIPT_DIR/translate-bin"
SETUP_SH="$SCRIPT_DIR/setup-deps.sh"

# --check: dry-run that verifies the install layout resolves correctly through
# whatever path the user invoked klaude on (PATH symlink, alias, etc.). Catches
# the SCRIPT_DIR-via-symlink class of bugs without spawning tmux/claude.
if [[ "${1:-}" == "--check" ]]; then
  printf '%-20s %s\n' "invoked-as:"     "${BASH_SOURCE[0]}"
  printf '%-20s %s\n' "resolved-self:"  "$SELF"
  printf '%-20s %s\n' "scripts-dir:"    "$SCRIPT_DIR"
  status=0
  for f in "$TRANSLATE_BIN" "$REPL_FULL" "$SETUP_SH"; do
    if [[ -e "$f" ]]; then
      printf '%-20s %s\n' "found:" "$f"
    else
      printf '%-20s %s\n' "MISSING:" "$f"; status=1
    fi
  done
  exit $status
fi

if [[ ! -x "$TRANSLATE_BIN" || "$SCRIPT_DIR/translate-bin.swift" -nt "$TRANSLATE_BIN" ]]; then
  info "translate-bin 컴파일 중..."
  if [[ ! -f "$SETUP_SH" ]]; then
    err "setup-deps.sh 를 찾을 수 없습니다 (resolved SCRIPT_DIR=$SCRIPT_DIR)"
    exit 1
  fi
  if ! bash "$SETUP_SH"; then
    err "Swift 바이너리 컴파일 실패. 수동 실행: bash $SETUP_SH"
    exit 1
  fi
fi

cleanup() {
  tmux kill-session -t "=$SESSION" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

CLAUDE_ARGS_QUOTED=""
case "$RESPONSE_LANG" in
  ko) CLAUDE_ARGS_QUOTED+=' --append-system-prompt '"$(printf '%q' 'Always respond in Korean (한국어). Only the user-facing prose should be Korean — keep code, identifiers, file paths, and shell commands as-is.')" ;;
  en) CLAUDE_ARGS_QUOTED+=' --append-system-prompt '"$(printf '%q' 'Always respond in English.')" ;;
  auto) ;;
esac

for arg in "$@"; do
  CLAUDE_ARGS_QUOTED+=" $(printf '%q' "$arg")"
done

tmux new-session -d -s "$SESSION" -n main "$CLAUDE_FULL$CLAUDE_ARGS_QUOTED"
CLAUDE_PANE="$(tmux list-panes -t "$SESSION:main" -F '#{pane_id}' | head -1)"

tmux split-window -h -b -l "${INPUT_WIDTH}%" -t "$CLAUDE_PANE" \
  "python3 $(printf '%q' "$REPL_FULL") $(printf '%q' "$CLAUDE_PANE")"

tmux select-pane -t "$CLAUDE_PANE"
tmux last-pane -t "$SESSION:main"

tmux attach -t "$SESSION"
